# ══════════════════════════════════════════════════════════════════
# FitSmart AI — .gitignore (Security-Hardened)
# ══════════════════════════════════════════════════════════════════

# ── Secrets & Environment Files ───────────────────────────────────
# NEVER commit API keys, secrets, or credentials
.env
.env.*
!.env.example
*.secret
*.secrets
*.key
*.keystore
*.jks
key.properties
local.properties
**/google-services.json
**/GoogleService-Info.plist
**/firebase_app_id_file.json

# ── Miscellaneous ─────────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/
.vscode/
*.code-workspace

# ── Flutter / Dart / Pub ──────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
build/
/coverage/
.packages

# ── Symbolication ─────────────────────────────────────────────────
app.*.symbols

# ── Obfuscation ───────────────────────────────────────────────────
app.*.map.json

# ── Android ───────────────────────────────────────────────────────
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/captures/
/android/gradlew
/android/gradlew.bat
/android/local.properties

# ── iOS / macOS ───────────────────────────────────────────────────
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/ephemeral/
**/macos/Flutter/ephemeral/
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Generated.xcconfig

# ── Web ───────────────────────────────────────────────────────────
# Keep sqlite3.wasm and drift_worker.js (needed at runtime)

# ── Generated / Cached ───────────────────────────────────────────
*.g.dart.bak
*.freezed.dart.bak
*.mocks.dart.bak
*.bak
