<?xml version="1.0" encoding="utf-8"?>
<!-- FitSmart small widget (2×1) — calories remaining ring + streak -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@android:color/transparent"
    android:padding="8dp">

    <!-- Calories ring (ProgressBar used as ring proxy) -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp">

        <ProgressBar
            android:id="@+id/widget_cal_ring"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:progress="0"
            android:max="100"
            android:rotation="-90"
            android:progressTint="#BDFF3A"
            android:progressBackgroundTint="#2A2A30" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_cal_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#BDFF3A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="kcal"
                android:textColor="#8A8A96"
                android:textSize="8sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Labels -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FitSmart"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- day streak 🔥"
            android:textColor="#8A8A96"
            android:textSize="10sp"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_updated_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#555560"
            android:textSize="8sp"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
