rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────
    /// Reject documents that would store more than 50 fields (DoS guard).
    function hasReasonableSize() {
      return request.resource.data.size() < 50;
    }

    /// True when the request is from the owner of this user subtree.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── User Profile + Gamification ──────────────────────────────
    // The top-level user document stores: profile, gamification, updatedAt.
    // NOTE: hasReasonableSize() uses request.resource which only exists on
    //       write operations — never apply it to read rules.
    match /users/{userId} {
      allow read:  if isOwner(userId);

      // User can write their own doc EXCEPT the premium fields, which are
      // admin-only (set manually after a verified bank transfer via the
      // Admin SDK / Firebase Console). This blocks a hostile client from
      // self-granting premium by writing { premium: true } to their doc.
      function premiumFieldsUntouched() {
        let touched = request.resource.data.diff(resource.data).affectedKeys();
        return !touched.hasAny(['premium', 'premiumExpiresAt']);
      }

      allow create: if isOwner(userId)
                    && hasReasonableSize()
                    && !request.resource.data.keys().hasAny(
                         ['premium', 'premiumExpiresAt']);
      allow update: if isOwner(userId)
                    && hasReasonableSize()
                    && premiumFieldsUntouched();
      allow delete: if isOwner(userId);

      // ── Meal Logs ──────────────────────────────────────────────
      match /meal_logs/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        allow delete: if isOwner(userId);
        allow update: if false; // meals are immutable once created
      }

      // ── Workout Logs ───────────────────────────────────────────
      match /workout_logs/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      // ── Weight Logs ────────────────────────────────────────────
      match /weight_logs/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      // ── AI Coach Conversations ─────────────────────────────────
      match /ai_conversations/{convId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        allow update: if isOwner(userId) && hasReasonableSize();
        allow delete: if isOwner(userId);
      }

      // ── AI Insights ────────────────────────────────────────────
      match /ai_insights/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        // Allow marking an insight as dismissed
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['dismissed']);
        allow delete: if isOwner(userId);
      }

      // ── Progress Photos metadata ───────────────────────────────
      match /progress_photos/{photoId} {
        allow read:  if isOwner(userId);
        allow write: if isOwner(userId) && hasReasonableSize();
      }

      // ── FCM Device Tokens ──────────────────────────────────────
      match /devices/{deviceId} {
        allow read:  if isOwner(userId);
        allow write: if isOwner(userId) && hasReasonableSize();
      }

      // ── Body Measurements ──────────────────────────────────────
      // Allow update to support deterministic-ID idempotent writes
      // (same logical event → same doc ID → set(merge:true) instead of duplicate).
      match /body_measurements/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize();
        allow update: if isOwner(userId) && hasReasonableSize();
        allow delete: if isOwner(userId);
      }

      // ── Quotas (server-enforced free-tier limits) ──────────────
      // Counters at users/{uid}/quotas/{YYYY-MM-DD}. Free users are capped
      // at AppConstants.freeTierDailyAiMessages / freeTierDailyPhotoAnalyses
      // (kept in sync with client constants — bump both together).
      // Premium users are capped at a much higher safety ceiling.
      match /quotas/{dayId} {
        allow read: if isOwner(userId);

        // Day ID must be YYYY-MM-DD (UTC), within a 2-day window from today
        // to allow timezone bleed but block backdated/forward writes.
        function validDayId() {
          return dayId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
        }

        function isPremium() {
          return request.auth.token.premium == true;
        }

        function aiMsgCap()   { return isPremium() ? 5000 : 20; }
        function photoCap()   { return isPremium() ? 500  : 1; }

        // Initial create — must start at exactly 1 on the counter being consumed
        // and 0 on the other.
        allow create: if isOwner(userId) && validDayId()
                      && request.resource.data.keys().hasOnly(
                           ['aiMessages', 'photoAnalyses', 'updatedAt'])
                      && (request.resource.data.aiMessages == 0
                          || request.resource.data.aiMessages == 1)
                      && (request.resource.data.photoAnalyses == 0
                          || request.resource.data.photoAnalyses == 1)
                      && (request.resource.data.aiMessages
                          + request.resource.data.photoAnalyses) == 1;

        // Increment by exactly 1 on exactly one counter, never decrement,
        // never exceed cap.
        allow update: if isOwner(userId) && validDayId()
                      && request.resource.data.keys().hasOnly(
                           ['aiMessages', 'photoAnalyses', 'updatedAt'])
                      && request.resource.data.aiMessages
                           >= resource.data.aiMessages
                      && request.resource.data.photoAnalyses
                           >= resource.data.photoAnalyses
                      && (request.resource.data.aiMessages
                          + request.resource.data.photoAnalyses)
                         - (resource.data.aiMessages
                            + resource.data.photoAnalyses) == 1
                      && request.resource.data.aiMessages    <= aiMsgCap()
                      && request.resource.data.photoAnalyses <= photoCap();

        allow delete: if false;
      }

      // ── Weekly Commitments ─────────────────────────────────────
      // User's commitment for the upcoming week, set during weekly review.
      // Doc ID = ISO week start date (YYYY-MM-DD of Monday).
      // Read + create are owner-only. Update allowed (mind change same week).
      // Delete denied — commitments are a record, not editable away.
      match /weekly_commitments/{weekId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && hasReasonableSize()
                      && weekId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
        allow update: if isOwner(userId) && hasReasonableSize();
        allow delete: if false;
      }

      // ── Workout Plans ──────────────────────────────────────────
      // Plans are large JSON blobs — skip field-count guard, doc-size limit applies.
      match /workout_plans/{docId} {
        allow read:  if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // ── Meal Plans ─────────────────────────────────────────────
      match /meal_plans/{docId} {
        allow read:  if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ── Analytics Events ─────────────────────────────────────────
    // Authenticated users may create their own event documents.
    // Pre-auth sessions (before sign-in) may also write using a
    // "pre_auth_" prefixed user_id so we capture nav/splash events.
    // Only the server (Firebase Console / Admin SDK) can read them.
    match /analytics_events/{eventId} {
      allow create: if hasReasonableSize()
                    && (
                      // Signed-in user writing their own event
                      (request.auth != null
                        && request.resource.data.user_id == request.auth.uid)
                      ||
                      // Pre-auth session (anonymous, before any auth)
                      (request.resource.data.user_id is string
                        && request.resource.data.user_id.matches('pre_auth_.*'))
                    );
      allow read, update, delete: if false;
    }

    // ── Catch-all: deny everything else ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
