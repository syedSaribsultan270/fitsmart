      "boundElements": null,
      "updated": 1744566400000,
      "link": null,
      "locked": false,
      "text": "CROSS-DEVICE SYNC\n\nFirestore paths:\nusers/{uid}.profile\nusers/{uid}.settings\nusers/{uid}.gamification\nusers/{uid}/ai_conversations\nusers/{uid}/meal_logs\nusers/{uid}/workout_logs\nusers/{uid}/weight_logs\n\nL1: SharedPreferences\nL2: Firestore (offline cache)\nL3: Server",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CROSS-DEVICE SYNC\n\nFirestore paths:\nusers/{uid}.profile\nusers/{uid}.settings\nusers/{uid}.gamification\nusers/{uid}/ai_conversations\nusers/{uid}/meal_logs\nusers/{uid}/workout_logs\nusers/{uid}/weight_logs\n\nL1: SharedPreferences\nL2: Firestore (offline cache)\nL3: Server",
      "lineHeight": 1.25
    },
