    {
      "id": "onb_txt",
      "type": "text",
      "x": 1222,
      "y": 92,
      "width": 476,
      "height": 530,
      "angle": 0,
      "strokeColor": "#ddd6fe",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1021,
      "version": 1,
      "versionNonce": 1021,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1744566400000,
      "link": null,
      "locked": false,
      "text": "Step 0   Welcome\nStep 1   Goal (lose fat / build muscle / maintain)\nStep 2   Bio (name, gender, age)\nStep 3   Body Stats (height, weight, BF%)\nStep 4   Location (country, city)\nStep 5   Activity Level\nStep 6   Dream Body (target physique)\nStep 7   Sleep (bedtime + wake time)\nStep 8   Diet (restrictions, cuisine, dislikes)\nStep 9   Budget (monthly food budget)\nStep 10  Targets (target weight, pace, gym days)\nStep 11  AI Setup → Complete\n\n─────────────────────────────────\nOn complete:\n  ✅ SharedPrefs: onboarding_data + uid\n  ✅ Firestore: users/{uid}.profile\n        { ...data, isComplete: true }\n  ✅ Firebase Analytics user properties\n        goal_type, activity_level, diet_type\n  ✅ GoRouter redirect → /dashboard\n\nSkip button (steps 1–10) → jumps to\ncompletion with partial data\nBack button (steps 1–10) → prev step",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 0   Welcome\nStep 1   Goal (lose fat / build muscle / maintain)\nStep 2   Bio (name, gender, age)\nStep 3   Body Stats (height, weight, BF%)\nStep 4   Location (country, city)\nStep 5   Activity Level\nStep 6   Dream Body (target physique)\nStep 7   Sleep (bedtime + wake time)\nStep 8   Diet (restrictions, cuisine, dislikes)\nStep 9   Budget (monthly food budget)\nStep 10  Targets (target weight, pace, gym days)\nStep 11  AI Setup → Complete\n\n─────────────────────────────────\nOn complete:\n  ✅ SharedPrefs: onboarding_data + uid\n  ✅ Firestore: users/{uid}.profile\n        { ...data, isComplete: true }\n  ✅ Firebase Analytics user properties\n        goal_type, activity_level, diet_type\n  ✅ GoRouter redirect → /dashboard\n\nSkip button (steps 1–10) → jumps to\ncompletion with partial data\nBack button (steps 1–10) → prev step",
      "lineHeight": 1.25
    },
