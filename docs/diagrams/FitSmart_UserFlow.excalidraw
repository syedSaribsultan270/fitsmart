    {
      "id": "ai_legend_txt",
      "type": "text",
      "x": 90,
      "y": 1120,
      "width": 470,
      "height": 174,
      "angle": 0,
      "strokeColor": "#67e8f9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1055,
      "version": 1,
      "versionNonce": 1055,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1744566400000,
      "link": null,
      "locked": false,
      "text": "AI TIER ROUTING\n① Gemini 2.5 Flash  (cloud, vision capable)\n② Groq Llama 3.3 70B  (cloud, text-only)\n③ Gemma 3 1B int4  (on-device ~529 MB)\n④ Template RAG  (deterministic, always available)\n\nImage in chat:   ① Gemini → ② Groq (text) → ③ → ④\nMeal photo:      ① Gemini → ④  (Groq skipped—text-only)\nText only:        ② Groq → ③ → ④\nCircuit breaker: opens after 2 Gemini failures (120s)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI TIER ROUTING\n① Gemini 2.5 Flash  (cloud, vision capable)\n② Groq Llama 3.3 70B  (cloud, text-only)\n③ Gemma 3 1B int4  (on-device ~529 MB)\n④ Template RAG  (deterministic, always available)\n\nImage in chat:   ① Gemini → ② Groq (text) → ③ → ④\nMeal photo:      ① Gemini → ④  (Groq skipped—text-only)\nText only:        ② Groq → ③ → ④\nCircuit breaker: opens after 2 Gemini failures (120s)",
      "lineHeight": 1.25
    },
    {
      "id": "sync_note",
      "type": "text",
      "x": 608,
      "y": 1112,
      "width": 148,
      "height": 190,
      "angle": 0,
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
